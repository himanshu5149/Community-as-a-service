rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny - Total Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function getGroupMember(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data;
    }

    function isGroupMember(groupId) {
      return isSignedIn() && exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
    }

    function isGroupAdmin(groupId) {
      return isSignedIn() && getGroupMember(groupId).role == 'admin';
    }

    function isGroupMod(groupId) {
      let role = getGroupMember(groupId).role;
      return isSignedIn() && (role == 'admin' || role == 'moderator');
    }

    function isSuperAdmin() {
      // Identity check against users collection
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- Entity Specific Validations ---
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'photoURL']) &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100 &&
             data.photoURL is string && data.photoURL.size() <= 500 &&
             (!data.keys().contains('bio') || (data.bio is string && data.bio.size() <= 500)) &&
             (!data.keys().contains('points') || (data.points is number)) &&
             (!data.keys().contains('level') || (data.level is number || data.level is string));
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['userId', 'userName', 'text', 'type', 'createdAt']) &&
             (data.userId == request.auth.uid || data.userId == 'system_ai' || data.userId == 'ai_moderator') &&
             data.text is string && data.text.size() <= 5000 &&
             data.type in ['text', 'image', 'video', 'audio', 'ai'] &&
             data.createdAt == request.time;
    }

    function isValidGroup(data) {
      return data.keys().hasAll(['name', 'slug', 'createdAt', 'createdBy']) &&
             data.name is string && data.name.size() <= 100 &&
             data.slug is string && data.slug.size() <= 100 &&
             data.createdBy == request.auth.uid &&
             data.createdAt == request.time;
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (isSuperAdmin() || request.query.limit <= 100);
      allow create: if isOwner(userId) && isValidUser(incoming()) && (incoming().role == 'user' || !incoming().keys().contains('role'));
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio', 'status', 'points', 'level', 'groups', 'updatedAt', 'lastLogin', 'tier', 'computeCredit', 'lastInvestment']);
    }

    match /users/{userId}/notifications/{notifId} {
      allow read: if isOwner(userId);
      allow create: if isSignedIn(); 
      allow update: if isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/points/{docId} {
      allow read, write: if isOwner(userId);
    }

    match /groups/{groupId} {
      allow read: if isSignedIn() && isValidId(groupId);
      allow create: if isSignedIn() && isValidId(groupId) && isValidGroup(incoming());
      allow update: if isGroupMod(groupId) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'accentColor', 'icon', 'category', 'memberCount']);
      allow delete: if isGroupAdmin(groupId);

      match /members/{memberId} {
        allow read: if isGroupMember(groupId) || (isSignedIn() && memberId == request.auth.uid);
        allow create: if isSignedIn() && (incoming().userId == request.auth.uid || isGroupAdmin(groupId));
        allow update: if isGroupAdmin(groupId);
        allow delete: if isGroupAdmin(groupId) || isOwner(memberId);
      }

      match /channels/{channelId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMod(groupId) || (isSignedIn() && get(/databases/$(database)/documents/groups/$(groupId)).data.createdBy == request.auth.uid);
        allow update: if isGroupMod(groupId);
        allow delete: if isGroupAdmin(groupId);
      }

      match /messages/{messageId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId) && isValidMessage(incoming());
        allow update: if isGroupMember(groupId) && (
          (existing().userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['text', 'isEdited', 'reactions'])) ||
          (isGroupMod(groupId) && (incoming().diff(existing()).affectedKeys().hasOnly(['isPinned', 'moderationStatus', 'moderationReason', 'moderationType', 'moderationConfidence', 'reactions'])))
        );
        allow delete: if isGroupMember(groupId) && (existing().userId == request.auth.uid || isGroupMod(groupId));
      }

      match /channels/{channelId}/messages/{messageId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId) && isValidMessage(incoming());
        allow update: if isGroupMember(groupId) && (
          (existing().userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['text', 'isEdited', 'reactions'])) ||
          (isGroupMod(groupId) && (incoming().diff(existing()).affectedKeys().hasOnly(['isPinned', 'moderationStatus', 'moderationReason', 'moderationType', 'moderationConfidence', 'reactions'])))
        );
        allow delete: if isGroupMember(groupId) && (existing().userId == request.auth.uid || isGroupMod(groupId));
      }

      match /events/{eventId} {
        allow read: if isGroupMember(groupId);
        allow create, update, delete: if isGroupMod(groupId);
      }

      match /polls/{pollId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMod(groupId);
        allow update: if isGroupMember(groupId);
      }
    }

    match /events_global/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['rsvps']));
    }

    match /conversations/{convId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in incoming().participants;
      allow update: if isSignedIn() && request.auth.uid in existing().participants && incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'lastMessageAt']);

      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants && isValidMessage(incoming());
        allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['text', 'isEdited', 'reactions']);
        allow delete: if isSignedIn() && existing().userId == request.auth.uid;
      }
    }

    match /blogPosts/{postId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /ai_agents/{agentId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || (isSignedIn() && incoming().groupId != null && isGroupAdmin(incoming().groupId));
    }

    match /ai_interactions/{intId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isSuperAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
    }

    match /friend_requests/{reqId} {
      allow read: if isSignedIn() && (resource.data.toId == request.auth.uid || resource.data.fromId == request.auth.uid);
      allow create: if isSignedIn() && incoming().fromId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.toId == request.auth.uid || resource.data.fromId == request.auth.uid);
    }

    match /friendships/{fId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.users;
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && request.auth.uid in resource.data.users;
    }

    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update: if isSuperAdmin();
    }

    match /bridge_suggestions/{sId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /spaces/{spaceId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
    }
  }
}
