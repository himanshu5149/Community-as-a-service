rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'royalisdevil@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin')
      );
    }

    function isGroupMember(groupId) {
      return isSignedIn() && exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
    }

    function isGroupMod(groupId) {
      return isGroupMember(groupId) && 
             get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.get('role', 'member') in ['admin', 'moderator'];
    }

    function isGroupAdmin(groupId) {
      return isGroupMember(groupId) && 
             get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.get('role', 'member') == 'admin';
    }

    // --- Core Collections ---

    match /users/{userId} {
      allow get, list: if true; 
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isSuperAdmin();
      
      match /notifications/{notifId} {
        allow read, update, delete: if isOwner(userId);
        allow create: if isSignedIn();
      }
      
      match /points/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /groups/{groupId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isGroupAdmin(groupId) || isSuperAdmin();

      match /members/{memberId} {
        allow read: if isGroupMember(groupId) || (isSignedIn() && memberId == request.auth.uid);
        allow write: if isGroupMod(groupId) || (isSignedIn() && memberId == request.auth.uid);
      }

      match /channels/{channelId} {
        allow read: if isGroupMember(groupId);
        allow write: if isGroupMod(groupId);

        match /messages/{messageId} {
          allow read: if isGroupMember(groupId);
          allow create: if isGroupMember(groupId);
          allow update, delete: if isGroupMember(groupId) && (existing().userId == request.auth.uid || isGroupMod(groupId));
        }
      }

      match /messages/{messageId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId);
        allow update, delete: if isGroupMember(groupId) && (existing().userId == request.auth.uid || isGroupMod(groupId));
      }

      match /events/{eventId} {
        allow read: if isGroupMember(groupId);
        allow create, update, delete: if isGroupMod(groupId);
      }
    }

    // --- Global Messaging & Social ---
    
    match /conversations/{convId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && request.auth.uid in existing().participants;
      allow update: if isSignedIn() && request.auth.uid in existing().participants;

      match /messages/{msgId} {
        // We use get() here to check parent conversation participants
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
      }
    }

    match /friend_requests/{reqId} {
      allow create: if isSignedIn() && incoming().fromId == request.auth.uid;
      allow read, update, delete: if isSignedIn() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
    }

    match /friendships/{fId} {
      allow read, delete: if isSignedIn() && request.auth.uid in resource.data.users;
      allow create: if isSignedIn();
    }

    // --- Admin & Meta ---

    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update: if isSuperAdmin();
    }

    match /ai_agents/{agentId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /ai_interactions/{intId} {
      allow read, write: if isSignedIn() && (resource.data.userId == request.auth.uid || isSuperAdmin());
    }

    match /spaces/{spaceId} {
      allow read, write: if isSignedIn();
    }
  }
}
