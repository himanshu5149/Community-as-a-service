rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isVerified() { return request.auth.token.email_verified == true; }
    
    function isGroupAdmin(groupId) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // --- Entities Validation ---
    
    function isValidGroup(data) {
      return data.keys().hasAll(['name', 'description', 'accentColor']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.description is string && data.description.size() <= 500 &&
             data.accentColor is string && data.accentColor.matches('^#[A-Fa-f0-9]{6}$');
    }

    function isValidMembership(data, userId, groupId) {
      return data.keys().hasAll(['userId', 'groupId', 'role', 'joinedAt']) &&
             data.userId == userId &&
             data.groupId == groupId &&
             data.role in ['admin', 'moderator', 'member'] &&
             data.joinedAt == request.time;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['userId', 'text', 'type', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.text is string && data.text.size() <= 5000 &&
             data.type in ['text', 'image', 'video', 'audio', 'ai'] &&
             data.createdAt == request.time;
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['title', 'description', 'hostId', 'startTime', 'endTime', 'eventType']) &&
             data.hostId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 2000 &&
             data.eventType in ['online', 'in-person'];
    }

    // --- Collection Routes ---

    match /groups/{groupId} {
      allow read: if true; // Public directory
      allow create: if isSignedIn() && isValidId(groupId) && isValidGroup(incoming());
      allow update: if isSignedIn() && isValidId(groupId) && isGroupAdmin(groupId) && isValidGroup(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'accentColor', 'icon', 'category', 'slug', 'memberCount'])
      );
      allow delete: if isGroupAdmin(groupId);

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isValidId(memberId) && isValidMembership(incoming(), request.auth.uid, groupId) && memberId == request.auth.uid;
        allow update: if isGroupAdmin(groupId) || (isOwner(memberId) && incoming().diff(existing()).affectedKeys().hasOnly(['userName', 'userAvatar']));
        allow delete: if isGroupAdmin(groupId) || isOwner(memberId);
      }

      match /channels/{channelId} {
        allow read: if isSignedIn();
        allow create: if isGroupAdmin(groupId) && isValidId(channelId);
        allow update: if isGroupAdmin(groupId);
        allow delete: if isGroupAdmin(groupId);

        match /messages/{messageId} {
          allow read: if isSignedIn();
          allow list: if isSignedIn() && (resource == null || resource.data.userId != null); 
          allow create: if isSignedIn() && isValidId(messageId) && isValidMessage(incoming());
          allow update: if isSignedIn() && (
             (isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['text', 'isEdited', 'reactions'])) ||
             (isGroupAdmin(groupId) && incoming().diff(existing()).affectedKeys().hasOnly(['isPinned', 'reactions'])) ||
             (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['reactions']))
          );
          allow delete: if isOwner(existing().userId) || isGroupAdmin(groupId);
        }
      }

      match /events/{eventId} {
        allow read: if true;
        allow create: if isSignedIn() && isValidId(eventId) && isValidEvent(incoming());
        allow update: if isSignedIn() && (
          (isOwner(existing().hostId) && isValidEvent(incoming())) ||
          (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['rsvps']) && incoming().rsvps.size() <= 1000)
        );
        allow delete: if isOwner(existing().hostId) || isGroupAdmin(groupId);
      }
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
      
      match /points/stats {
        allow read: if isOwner(userId);
        allow write: if false; // System only
      }
    }

    match /conversations/{convId} {
      allow read: if isSignedIn() && isValidId(convId) && request.auth.uid in existing().participants;
      allow create: if isSignedIn() && isValidId(convId) && request.auth.uid in incoming().participants;
      allow update: if isSignedIn() && isValidId(convId) && request.auth.uid in existing().participants;

      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if isSignedIn() && isValidId(messageId) && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants && isValidMessage(incoming());
      }
    }

    match /ai_agents/{agentId} {
      allow read: if true;
      allow write: if false; 
    }

    match /events_global/{eventId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(eventId) && isValidEvent(incoming());
      allow update: if isSignedIn() && isValidId(eventId) && (
        (isOwner(existing().hostId) && isValidEvent(incoming())) ||
        (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['rsvps']) && incoming().rsvps.size() <= 1000)
      );
    }
    
    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update, delete: if false; 
    }
  }
}
