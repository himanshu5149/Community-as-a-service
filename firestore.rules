rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { 
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.firebase.sign_in_provider == 'google.com'
      ); 
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isGlobalAdmin() {
      return isSignedIn() && request.auth.token.email == 'royalisdevil@gmail.com';
    }

    function isMemberOfGroup(groupId) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)) ||
        isGlobalAdmin()
      );
    }

    function isGroupAdmin(groupId) {
      let memberPath = /databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid);
      return isGlobalAdmin() || (
        isSignedIn() && 
        exists(memberPath) &&
        get(memberPath).data.role == 'admin'
      );
    }

    // --- Users ---
    match /users/{userId} {
      allow get, list, create, update: if isSignedIn();
      
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isGlobalAdmin();
      }
      
      match /notifications/{notifId} {
        allow create: if isSignedIn();
      }
    }

    // --- Groups ---
    match /groups/{groupId} {
      allow get, list, create: if isSignedIn(); 
      allow update, delete: if isGroupAdmin(groupId) || isGlobalAdmin();

      match /{allSubcollections=**} {
        allow read, list, create: if isSignedIn();
        allow update, delete: if isMemberOfGroup(groupId) || isGlobalAdmin();
      }
      
      match /members/{memberId} {
        allow update, delete: if isGroupAdmin(groupId) || isOwner(memberId) || isGlobalAdmin();
      }
      
      match /channels/{channelId} {
        allow write: if isGroupAdmin(groupId) || isGlobalAdmin();
      }
    }

    // --- Conversations & Direct Messages ---
    match /conversations/{convId} {
      allow get, list, create, update, delete: if isSignedIn();
      match /{allSub=**} {
         allow read, list, write: if isSignedIn();
      }
    }

    // --- Social ---
    match /friend_requests/{requestId} {
      allow read, list, create, update, delete: if isSignedIn();
    }
    match /friendships/{friendshipId} {
      allow read, list, create, delete: if isSignedIn();
    }

    // --- Messages (Universal Access for Logged In) ---
    match /{path=**}/messages/{messageId} {
       allow read, list, create: if isSignedIn(); 
       allow update, delete: if isOwner(existing().userId) || isGlobalAdmin();
    }

    // --- Community & Global ---
    match /blogPosts/{postId} { allow read, list: if true; allow write: if isGlobalAdmin(); }
    match /events_global/{eventId} { allow read, list, create: if isSignedIn(); allow update, delete: if isSignedIn(); }
    match /reports/{reportId} { 
      allow create: if isSignedIn(); 
      allow read, list: if isGlobalAdmin() || (isSignedIn() && resource.data.reporterId == request.auth.uid);
      allow update: if isGlobalAdmin() || (isSignedIn() && resource.data.reporterId == request.auth.uid); 
    }
    match /ai_agents/{agentId} { allow read, list: if isSignedIn(); allow write: if isGlobalAdmin(); }
    match /ai_interactions/{interactionId} { allow create: if isSignedIn(); allow read, list: if isSignedIn(); }
    match /bridge_suggestions/{sugId} { allow read, list, create: if isSignedIn(); allow update, delete: if isGlobalAdmin(); }
    match /spaces/{spaceId} { allow read, list, create, update, delete: if isSignedIn(); }
    match /polls/{pollId} { allow read, list, create, update: if isSignedIn(); allow delete: if isGlobalAdmin(); }
  }
}
