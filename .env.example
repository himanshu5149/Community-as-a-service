# ==============================================================================
# PRODUCTION ENV CONFIGURATION BLUEPRINT FOR CaaS SYSTEM
# ==============================================================================

# 1. FIREBASE ADMIN SERVICE ACCOUNT CONFIGURATION
# ------------------------------------------------------------------------------
# Option A: Single JSON credentials string (useful for Cloud platforms like Railway, Heroku)
# Note: Ensure the privateKey has escaped newlines literal "\n" replacement logic inside the initialization file.
FIREBASE_ADMIN_KEY={"type": "service_account", "projectId": "your-firebase-project-id", "privateKeyId": "...", "privateKey": "-----\nBEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n", "clientEmail": "firebase-adminsdk-xxxxx@your-firebase-project.iam.gserviceaccount.com"}

# Option B: Individual Service Account attributes (safe, fallback methodology)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# 2. AI CLIENT SERVICES SECRETS
# ------------------------------------------------------------------------------
# API Secret Key for the Google GenAI library (used in server API triggers)
GEMINI_API_KEY=your_gemini_api_key_here

# 3. PAYMENT SYSTEMS INTEGRATION (LEMONSQUEEZY)
# ------------------------------------------------------------------------------
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_api_key_here
LEMONSQUEEZY_STORE_ID=your_store_id_here
LEMONSQUEEZY_WEBHOOK_SECRET=your_signature_verification_secret_here

# Client configuration attributes
VITE_LEMONSQUEEZY_STORE=caas
VITE_LS_STARTER_VARIANT_ID=your_starter_variant_id_here
VITE_LS_PROFESSIONAL_VARIANT_ID=your_professional_variant_id_here

# 4. CROSS-ORIGIN DEPLOYMENT HOOK
# ------------------------------------------------------------------------------
# Set this on your frontend Vercel deployment to point directly to your backend service 
# (e.g. Firebase Cloud Functions endpoint). If blank, default to local relative path "/api".
VITE_API_URL=https://us-central1-gen-lang-client-0925216525.cloudfunctions.net
