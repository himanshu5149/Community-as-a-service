{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public and private information about a user.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "onboardingCompleted": { "type": "boolean" },
        "plan": { "type": "string", "enum": ["free", "pro", "elite", "founder"] },
        "subscriptionId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "photoURL", "role"]
    },
    "Group": {
      "title": "Community Node",
      "description": "A group/server in the platform.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "type": { "type": "string", "enum": ["open", "invite"] },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "memberCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isPublic": { "type": "boolean" }
      },
      "required": ["name", "ownerId", "type"]
    },
    "Member": {
      "title": "Group Member",
      "description": "A user's membership details in a group.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["member", "moderator", "admin"] },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "role"]
    },
    "Channel": {
      "title": "Communication Channel",
      "description": "A text or voice channel within a group.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "voice"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["name", "type", "createdAt"]
    },
    "Message": {
      "title": "Message Signal",
      "description": "A message sent in a channel or direct chat.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userAvatar": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "image", "video", "audio", "ai"] },
        "fileUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isAI": { "type": "boolean" },
        "aiRole": { "type": "string" },
        "aiColor": { "type": "string" },
        "reactions": { "type": "object" },
        "isEdited": { "type": "boolean" },
        "isPinned": { "type": "boolean" },
        "moderationStatus": { "type": "string" }
      },
      "required": ["userId", "text", "type", "createdAt"]
    }
  },
  "firestore": {
    "/users": {
      "schema": "User",
      "description": "Collection of all user profiles."
    },
    "/groups": {
      "schema": "Group",
      "description": "Collection of all community nodes."
    },
    "/groups/{groupId}/members": {
      "schema": "Member",
      "description": "Members of a specific group."
    },
    "/groups/{groupId}/channels": {
      "schema": "Channel",
      "description": "Channels within a group."
    },
    "/groups/{groupId}/channels/{channelId}/messages": {
      "schema": "Message",
      "description": "Messages in a specific channel."
    }
  }
}
