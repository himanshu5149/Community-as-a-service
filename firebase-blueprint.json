{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public and private information about a user.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin", "banned"] },
        "onboardingCompleted": { "type": "boolean" },
        "plan": { "type": "string", "enum": ["free", "pro", "elite", "founder"] },
        "subscriptionId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "photoURL", "role"]
    },
    "Group": {
      "title": "Community Node",
      "description": "A group/server in the platform.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "type": { "type": "string", "enum": ["open", "invite"] },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "memberCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isPublic": { "type": "boolean" }
      },
      "required": ["name", "ownerId", "type"]
    },
    "Member": {
      "title": "Group Member",
      "description": "A user's membership details in a group.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["member", "moderator", "admin"] },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "role"]
    },
    "Channel": {
      "title": "Communication Channel",
      "description": "A text or voice channel within a group.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "voice"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["name", "type", "createdAt"]
    },
    "Message": {
      "title": "Message Signal",
      "description": "A message sent in a channel or direct chat.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userAvatar": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "image", "video", "audio", "ai"] },
        "fileUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isAI": { "type": "boolean" },
        "aiRole": { "type": "string" },
        "aiColor": { "type": "string" },
        "reactions": { "type": "object" },
        "isEdited": { "type": "boolean" },
        "isPinned": { "type": "boolean" },
        "moderationStatus": { "type": "string" }
      },
      "required": ["userId", "text", "type", "createdAt"]
    },
    "AIAgent": {
      "title": "AI Persona",
      "description": "Definition of a specialized AI agent.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "description": { "type": "string" },
        "personality": { "type": "string" },
        "expertise": { "type": "array", "items": { "type": "string" } },
        "avatarUrl": { "type": "string" },
        "accentColor": { "type": "string" },
        "creatorId": { "type": "string" },
        "groupId": { "type": "string" },
        "isCrossGroup": { "type": "boolean" },
        "model": { "type": "string" },
        "totalResponses": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "role", "personality", "expertise"]
    },
    "Space": {
      "title": "Neural Space",
      "description": "A collaborative hybrid room across communities.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "connectedGroups": { "type": "array", "items": { "type": "string" } },
        "members": { "type": "array", "items": { "type": "string" } },
        "lastActivity": { "type": "string", "format": "date-time" },
        "tasks": { "type": "array" }
      },
      "required": ["name", "connectedGroups"]
    },
    "Report": {
      "title": "Moderation Report",
      "description": "A community report of toxic or malicious content.",
      "type": "object",
      "properties": {
        "reporterId": { "type": "string" },
        "targetType": { "type": "string", "enum": ["message", "member", "group"] },
        "targetId": { "type": "string" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "resolved", "dismissed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["reporterId", "targetType", "targetId", "status"]
    },
    "BlogPost": {
      "title": "CaaS Journal Post",
      "description": "An article or guide for CaaS practitioners.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "author": { "type": "string" },
        "imageUrl": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "excerpt", "content", "category", "author"]
    },
    "FriendRequest": {
      "title": "Friend Request Link",
      "description": "A pending friend request from one user to another.",
      "type": "object",
      "properties": {
        "fromId": { "type": "string" },
        "toId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fromId", "toId", "status"]
    },
    "Friendship": {
      "title": "Friendship Node",
      "description": "An established mutual link between two users.",
      "type": "object",
      "properties": {
        "users": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["users"]
    },
    "BridgeSuggestion": {
      "title": "Neural Bridge Suggestion",
      "description": "AI-generated connection suggestion between posts and groups.",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "fromGroup": { "type": "string" },
        "suggestedGroup": { "type": "string" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "fromGroup", "suggestedGroup", "status"]
    },
    "Notification": {
      "title": "Signal Notification",
      "description": "A notification regarding activity relevant to a user.",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "link": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "title", "message", "isRead"]
    },
    "Conversation": {
      "title": "Conversation Link",
      "description": "Private direct message channel between users.",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "participantData": { "type": "object" },
        "lastSenderId": { "type": "string" },
        "lastRead": { "type": "object" }
      },
      "required": ["participants", "lastMessageAt"]
    },
    "Event": {
      "title": "Community Event",
      "description": "An event hosted online or in-person in the community.",
      "type": "object",
      "properties": {
        "groupId": { "type": "string" },
        "hostId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "eventType": { "type": "string", "enum": ["online", "in-person"] },
        "meetingLink": { "type": "string" },
        "maxAttendees": { "type": "number" },
        "rsvps": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["groupId", "hostId", "title", "description", "startTime", "endTime", "eventType"]
    }
  },
  "firestore": {
    "/ai_agents": {
      "schema": "AIAgent",
      "description": "Collection of all AI personas."
    },
    "/users": {
      "schema": "User",
      "description": "Collection of all user profiles."
    },
    "/users/{userId}/notifications": {
      "schema": "Notification",
      "description": "User notification alerts."
    },
    "/groups": {
      "schema": "Group",
      "description": "Collection of all community nodes."
    },
    "/groups/{groupId}/members": {
      "schema": "Member",
      "description": "Members of a specific group."
    },
    "/groups/{groupId}/channels": {
      "schema": "Channel",
      "description": "Channels within a group."
    },
    "/groups/{groupId}/channels/{channelId}/messages": {
      "schema": "Message",
      "description": "Messages in a specific channel."
    },
    "/groups/{groupId}/events": {
      "schema": "Event",
      "description": "Events within a community node."
    },
    "/events_global": {
      "schema": "Event",
      "description": "Global events open to all users."
    },
    "/conversations": {
      "schema": "Conversation",
      "description": "Private text chat links between members."
    },
    "/conversations/{convId}/messages": {
      "schema": "Message",
      "description": "Direct chat messages."
    },
    "/spaces": {
      "schema": "Space",
      "description": "Collaborative hybrid spaces across community nodes."
    },
    "/reports": {
      "schema": "Report",
      "description": "User-submitted moderation content flags."
    },
    "/blogPosts": {
      "schema": "BlogPost",
      "description": "Scientific field journals and articles."
    },
    "/friend_requests": {
      "schema": "FriendRequest",
      "description": "Link request proposals between nodes."
    },
    "/friendships": {
      "schema": "Friendship",
      "description": "Established communication links."
    },
    "/bridge_suggestions": {
      "schema": "BridgeSuggestion",
      "description": "AI-generated network suggestion bridges."
    }
  }
}
